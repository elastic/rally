#!/bin/sh
# Delegate to `make pre-commit` (venv + uv + pre-commit) from the repo root.
# Enable with: git config core.hooksPath scripts/githooks
#
# Requires `make` on PATH and a synced dev env (`make install` or `make venv`); see Makefile pre-commit target.

set -eu

if ! git rev-parse --git-dir >/dev/null 2>&1; then
	exit 0
fi

root=$(git rev-parse --show-toplevel)
cd "$root"

exec make pre-commit
