#!/bin/sh
# Run project linters/formatters before each commit (same as `make pre-commit`: uv + pre-commit).
# Enable with: git config core.hooksPath scripts/githooks
#
# Requires uv (https://docs.astral.sh/uv/) and a synced dev env (`make install` or `make venv`).

set -eu

if ! git rev-parse --git-dir >/dev/null 2>&1; then
	exit 0
fi

root=$(git rev-parse --show-toplevel)
cd "$root"

exec uv run -- pre-commit run
